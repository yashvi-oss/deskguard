# Server
NODE_ENV=development
PORT=5000

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deskguard
DB_USER=deskguard_user
DB_PASSWORD=deskguard_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-this

# Timers (in seconds)
SESSION_TIMEOUT=7200
AWAY_TIMEOUT=1200
PROMPT_INTERVAL=7200

# CORS
CORS_ORIGIN=http://localhost:3000
